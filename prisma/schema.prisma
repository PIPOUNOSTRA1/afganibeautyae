generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  NEW
  CONFIRMED
  SHIPPED
  CANCELLED
}

enum PaymentMethod {
  COD
  CARD
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String   @default("admin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Product {
  id           String         @id @default(cuid())
  slug         String         @unique
  name         String
  englishName  String
  category     String
  description  String
  price        Decimal        @db.Decimal(10, 2)
  compareAt    Decimal        @db.Decimal(10, 2)
  cost         Decimal        @db.Decimal(10, 2)
  shippingCost Decimal        @db.Decimal(10, 2)
  stock        Int            @default(0)
  videoUrl     String?
  rating       Decimal        @db.Decimal(2, 1)
  reviewCount  Int            @default(0)
  isBestSeller Boolean        @default(false)
  isNew        Boolean        @default(true)
  images       ProductImage[]
  reviews      Review[]
  orderItems   OrderItem[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Customer {
  id         String   @id @default(cuid())
  name       String
  phone      String   @unique
  email      String?
  country    String
  city       String?
  address    String?
  orders     Order[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Order {
  id            String        @id @default(cuid())
  publicNumber  String        @unique
  customerId    String
  customer      Customer      @relation(fields: [customerId], references: [id])
  items         OrderItem[]
  total         Decimal       @db.Decimal(10, 2)
  status        OrderStatus   @default(NEW)
  paymentMethod PaymentMethod @default(COD)
  country       String
  city          String
  address       String
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

model Review {
  id         String   @id @default(cuid())
  productId  String
  name       String
  rating     Int
  comment    String
  isVerified Boolean  @default(true)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PixelSetting {
  id        String   @id @default(cuid())
  provider  String
  key       String
  value     String
  isSecret  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, key])
}

model ProfitSnapshot {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  productCost Decimal  @db.Decimal(10, 2)
  shippingCost Decimal @db.Decimal(10, 2)
  adSpend     Decimal  @db.Decimal(10, 2)
  revenue     Decimal  @db.Decimal(10, 2)
  clicks      Int
  impressions Int
  purchases   Int
  netProfit   Decimal  @db.Decimal(10, 2)
}